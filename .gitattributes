# Auto-detect text files, normalize line endings to LF on commit
* text=auto

# Shell scripts must use LF
*.sh text eol=lf

# TypeScript/JSON use LF
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.js text eol=lf

# Markdown use LF
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.db binary
*.node binary
